{
  "name": "skyguide-skse",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "deploy": "cp dist/skyguide.js \"/mnt/c/Program Files (x86)/Steam/steamapps/common/Skyrim Special Edition/Data/Platform/Plugins/skyguide.js\"",
    "check:runtime": "node scripts/check-skyrim-runtime.js",
    "verify:skyrim": "pnpm build && pnpm check:runtime",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxlint --fix"
  },
  "dependencies": {
    "@skyrim-platform/skyrim-platform": "*"
  },
  "devDependencies": {
    "oxlint": "^0.16.0",
    "tsdown": "^0.9.0",
    "typescript": "^5.0.0"
  }
}
